# انسخ الملف ده باسم .env واملأ القيم الحقيقية
# لا ترفع ملف .env نفسه على GitHub أبداً

# من Supabase: Project Settings > Database > Connection string (URI) > Session pooler أو Direct
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# أي نص عشوائي طويل (استخدم: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-this-to-a-random-secret-key

# ---------- إشعارات الفواتير المتأخرة (اختياري) ----------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
NOTIFY_EMAIL_TO=you@example.com

# سر عشوائي يحمي endpoint الكرون بتاع الفواتير المتأخرة
CRON_SECRET=change-this-to-a-random-secret-too
